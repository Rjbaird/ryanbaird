---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const project = await getEntry("projects", Astro.params.slug ?? "");

if (!project || project.data.draft) {
  Astro.response.status = 404;
  return Astro.rewrite("/404");
}

const { Content } = await render(project);
const imagePath = `/assets/${project.data.img.split("/").pop()}`;
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  image={imagePath}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    name: project.data.title,
    description: project.data.description,
    url: new URL(`/projects/${project.id}/`, Astro.site).toString(),
    datePublished: project.data.pubDate.toISOString(),
    dateModified: project.data.updatedDate?.toISOString(),
    image: new URL(imagePath, Astro.site).toString(),
    creator: {
      "@type": "Person",
      name: "Ryan Baird",
      url: Astro.site?.toString(),
    },
  }}
>
  <article class="section prose">
    <p class="eyebrow">{project.data.category}</p>
    <h1>{project.data.title}</h1>
    <p class="meta">{project.data.description}</p>
    <img src={imagePath} alt="" loading="eager" />
    <div class="button-row">
      {project.data.url && <a class="button" href={project.data.url}>Visit site</a>}
      {project.data.github && <a class="button secondary" href={project.data.github}>Source</a>}
    </div>
    <Content />
  </article>
</BaseLayout>
