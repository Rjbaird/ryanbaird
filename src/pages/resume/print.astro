---
import ResumeDocument from "../../components/ResumeDocument.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex" />
    <title>Ryan Baird Resume</title>
  </head>
  <body>
    <ResumeDocument print />
  </body>
</html>

<style is:global>
  :root {
    --ink: #191919;
    --muted: #4f5863;
    --accent-strong: #7c2d12;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  @page {
    size: letter;
    margin: 0.45in;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: white;
    color: var(--ink);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  @media screen {
    body {
      display: grid;
      min-height: 100vh;
      place-items: start center;
      background: #e7e4de;
      padding: 24px;
    }

    .resume-document {
      width: 8.5in;
      min-height: 11in;
      background: white;
      box-shadow: 0 20px 60px rgb(0 0 0 / 16%);
      padding: 0.45in;
    }
  }
</style>
