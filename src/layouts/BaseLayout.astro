---
const {
  title = "Ryan Baird",
  description = "Developer portfolio and writing by Ryan Baird.",
  image = "/assets/baird-portfolio-project.jpg",
  type = "website",
  structuredData,
} = Astro.props;
const pageTitle = title === "Ryan Baird" ? title : `${title} | Ryan Baird`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = new URL(image, Astro.site).toString();
const defaultStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Ryan Baird",
    url: Astro.site?.toString(),
    sameAs: [
      "https://github.com/Rjbaird",
      "https://www.linkedin.com/in/bairdryan/",
    ],
    jobTitle: "Software Developer",
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Ryan Baird",
    url: Astro.site?.toString(),
  },
];
const jsonLd = structuredData
  ? [...defaultStructuredData, ...(Array.isArray(structuredData) ? structuredData : [structuredData])]
  : defaultStructuredData;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#222222" />
    <meta name="color-scheme" content="dark" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Ryan Baird RSS" href="/rss.xml" />
    <link rel="icon" href="/favicon.ico" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="module" src="/vendor/datastar-1.0.2.js"></script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Ryan Baird home"><span>[</span>Ryan Baird<span>]</span></a>
      <nav aria-label="Primary navigation">
        <a href="/projects/">Projects</a>
        <a href="/work/">Work</a>
        <a class="nav-button" href="/contact/">Contact</a>
      </nav>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy;2026 <span>Ryan Baird</span> <span class="footer-divider">|</span> <span>All rights reserved.</span></p>
      <nav aria-label="Footer links">
        <a href="https://github.com/Rjbaird">GitHub</a>
        <a href="https://www.linkedin.com/in/bairdryan/">LinkedIn</a>
        <a href="/contact/">Contact</a>
        <a href="/privacy/">Privacy</a>
        <a href="/ai/">AI</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --ink: #f0f0f0;
    --muted: #d1d5db;
    --line: #525252;
    --paper: #222222;
    --panel: #2b2b2b;
    --accent: #f87171;
    --accent-blue: #60a5fa;
    --accent-strong: #818cf8;
    --soft: #333333;
    --warn: #facc15;
    font-family:
      "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
      monospace;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    line-height: 1.6;
    font-size: 1.125rem;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: var(--accent-blue);
    text-decoration-color: color-mix(in srgb, var(--accent-blue) 60%, transparent);
    text-underline-offset: 0.25em;
  }

  a:hover {
    color: var(--accent);
  }

  :focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 3px;
  }

  .skip-link {
    left: 16px;
    padding: 0.65rem 0.9rem;
    position: fixed;
    top: 12px;
    transform: translateY(-160%);
    z-index: 100;
    border-radius: 8px;
    background: var(--ink);
    color: var(--paper);
    font-weight: 750;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-header,
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(896px, calc(100% - 32px));
    margin: 0 auto;
    padding: 24px 0;
  }

  .brand {
    color: white;
    font-size: 1.25rem;
    font-weight: 500;
    text-decoration: none;
  }

  .brand span {
    color: var(--accent);
  }

  .brand:hover {
    color: white;
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 2px;
    text-underline-offset: 0.25em;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
  }

  nav a {
    color: white;
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    text-transform: uppercase;
  }

  nav a:not(.nav-button) {
    letter-spacing: 0.12em;
  }

  nav a:hover {
    color: var(--accent);
  }

  .nav-button {
    border: 1px solid var(--accent);
    border-radius: 6px;
    padding: 0.2rem 0.5rem;
    letter-spacing: 0.12em;
  }

  main {
    min-height: 70vh;
  }

  .section {
    width: min(896px, calc(100% - 32px));
    margin: 0 auto;
    padding: 40px 0;
  }

  .section.compact {
    padding-top: 28px;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(260px, 0.65fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    padding-top: 20px;
  }

  .hero h1,
  .page-heading h1 {
    max-width: 12ch;
    margin: 0;
    color: var(--accent);
    font-size: clamp(2.5rem, 7vw, 5.4rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .hero p,
  .page-heading p {
    max-width: 680px;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.2rem);
  }

  .hero-portrait {
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    background: var(--panel);
  }

  .hero-portrait img {
    aspect-ratio: 4 / 5;
    height: 100%;
    object-fit: cover;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.65rem 0.95rem;
    border: 1px solid var(--ink);
    border-radius: 8px;
    background: var(--accent);
    color: #111111;
    font-weight: 750;
    text-decoration: none;
  }

  .button.secondary {
    background: transparent;
    border-color: var(--accent);
    color: white;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }

  .section-heading h2,
  .page-heading h1 {
    margin-top: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .project-card,
  .list-card,
  .job-card {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    overflow: hidden;
  }

  .resume-list {
    display: grid;
    gap: 1rem;
  }

  .job-card ul {
    margin: 0.8rem 0 0;
    padding-left: 1.2rem;
  }

  .job-card li + li {
    margin-top: 0.35rem;
  }

  .qr-tool {
    display: grid;
    gap: 1.25rem;
  }

  .field-label {
    display: block;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  select {
    width: min(100%, 360px);
    min-height: 44px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: white;
    color: #111111;
    font: inherit;
    padding: 0.55rem 0.75rem;
  }

  input {
    min-height: 44px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: white;
    color: #111111;
    font: inherit;
    padding: 0.55rem 0.75rem;
  }

  input[type="color"] {
    width: 100%;
    padding: 0.25rem;
  }

  .qr-designer-layout {
    display: grid;
    grid-template-columns: minmax(280px, 0.92fr) minmax(320px, 1.08fr);
    gap: 1.25rem;
    align-items: start;
  }

  .qr-controls {
    display: grid;
    gap: 1.1rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    padding: 1rem;
  }

  .control-group,
  .qr-controls label {
    display: grid;
    gap: 0.45rem;
  }

  .control-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .qr-result {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 1.25rem;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    padding: 1rem;
  }

  .qr-preview {
    display: grid;
    aspect-ratio: 1;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: white;
    padding: 0.75rem;
  }

  .qr-preview img {
    width: 100%;
  }

  .qr-result.designer {
    grid-template-columns: 260px minmax(0, 1fr);
    align-items: start;
  }

  qr-code-designer,
  .qr-code-designer-shell {
    display: block;
  }

  .qr-code-designer-shell {
    display: grid;
    gap: 1rem;
  }

  .qr-code-designer-preview {
    display: grid;
    min-height: 280px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: white;
    padding: 1rem;
  }

  .qr-code-designer-preview svg,
  .qr-code-designer-preview canvas {
    max-width: 100%;
    height: auto;
  }

  .qr-code-designer-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .qr-code-designer-actions button {
    min-height: 44px;
    border: 1px solid var(--ink);
    border-radius: 8px;
    background: var(--accent);
    color: #111111;
    cursor: pointer;
    font: inherit;
    font-weight: 750;
    padding: 0.65rem 0.95rem;
  }

  .qr-code-designer-actions button.secondary {
    background: transparent;
    border-color: var(--accent);
    color: white;
  }

  .project-image {
    display: block;
    background: var(--soft);
  }

  .project-image img {
    aspect-ratio: 16 / 10;
    width: 100%;
    object-fit: cover;
  }

  .project-copy,
  .list-card,
  .job-card {
    padding: 1.1rem;
  }

  .project-copy h3,
  .list-card h2,
  .job-card h2 {
    margin: 0.2rem 0 0.45rem;
    line-height: 1.18;
  }

  .project-copy p,
  .list-card p,
  .job-card p {
    color: var(--muted);
  }

  .project-copy h3 a,
  .list-card h2 a,
  .job-card h2 a {
    color: white;
  }

  .eyebrow {
    margin: 0;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.9rem;
  }

  .tag-row span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.18rem 0.55rem;
    color: white;
    font-size: 0.82rem;
    font-weight: 650;
  }

  .split {
    display: grid;
    grid-template-columns: 0.78fr 1.22fr;
    gap: 2rem;
    align-items: start;
  }

  .prose {
    max-width: 760px;
  }

  .prose h1 {
    margin-bottom: 0.5rem;
    font-size: clamp(2.4rem, 5vw, 4.8rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .prose p,
  .prose li {
    color: white;
  }

  .prose h1 {
    color: var(--accent);
  }

  .prose h2 {
    color: var(--accent-strong);
  }

  .prose h3 {
    color: var(--muted);
  }

  .prose strong {
    color: var(--warn);
  }

  .prose del {
    color: var(--muted);
  }

  .datastar-note {
    margin-top: 2rem;
    border-top: 1px solid var(--line);
    padding-top: 1.25rem;
  }

  .prose img {
    border-radius: 8px;
  }

  .meta {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .site-footer {
    border-top: 1px solid var(--line);
    color: var(--muted);
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    position: sticky;
    top: 100vh;
  }

  .site-footer p {
    margin: 0;
    color: white;
    font-size: 0.875rem;
  }

  .footer-divider {
    color: var(--accent);
  }

  @media (max-width: 820px) {
    .site-header,
    .site-footer,
    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero,
    .split {
      grid-template-columns: 1fr;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .qr-result {
      grid-template-columns: 1fr;
    }

    .qr-designer-layout,
    .qr-result.designer,
    .control-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-top: 28px;
    }
  }
</style>
