---
const {
  title = "Ryan Baird",
  description = "Developer portfolio and writing by Ryan Baird.",
  image = "/assets/baird-portfolio-project.jpg",
  type = "website",
  structuredData,
} = Astro.props;
const pageTitle = title === "Ryan Baird" ? title : `${title} | Ryan Baird`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = new URL(image, Astro.site).toString();
const defaultStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Ryan Baird",
    url: Astro.site?.toString(),
    sameAs: [
      "https://github.com/Rjbaird",
      "https://www.linkedin.com/in/ryanbaird/",
    ],
    jobTitle: "Software Developer",
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Ryan Baird",
    url: Astro.site?.toString(),
  },
];
const jsonLd = structuredData
  ? [...defaultStructuredData, ...(Array.isArray(structuredData) ? structuredData : [structuredData])]
  : defaultStructuredData;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#fbfaf7" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Ryan Baird RSS" href="/rss.xml" />
    <link rel="icon" href="/favicon.ico" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="module" src="/vendor/datastar-1.0.2.js"></script>
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header">
      <a class="brand" href="/">Ryan Baird</a>
      <nav aria-label="Primary navigation">
        <a href="/projects/">Projects</a>
        <a href="/blog/">Blog</a>
        <a href="/work/">Work</a>
        <a href="/ryan-baird-resume.pdf">Resume</a>
      </nav>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <nav aria-label="Footer links">
        <a href="https://github.com/Rjbaird">GitHub</a>
        <a href="https://www.linkedin.com/in/ryanbaird/">LinkedIn</a>
        <a href="/privacy/">Privacy</a>
        <a href="/ai/">AI</a>
        <a href="/rss.xml">RSS</a>
      </nav>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #191919;
    --muted: #5b626b;
    --line: #d9dee5;
    --paper: #fbfaf7;
    --panel: #ffffff;
    --accent: #0f766e;
    --accent-strong: #7c2d12;
    --soft: #edf5f4;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    line-height: 1.6;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration-color: color-mix(in srgb, currentColor 35%, transparent);
    text-underline-offset: 0.2em;
  }

  a:hover {
    color: var(--accent);
  }

  :focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 3px;
  }

  .skip-link {
    left: 16px;
    padding: 0.65rem 0.9rem;
    position: fixed;
    top: 12px;
    transform: translateY(-160%);
    z-index: 100;
    border-radius: 8px;
    background: var(--ink);
    color: white;
    font-weight: 750;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-header,
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 24px 0;
  }

  .brand {
    font-weight: 800;
    text-decoration: none;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem 1.1rem;
  }

  nav a {
    color: var(--muted);
    font-size: 0.95rem;
    font-weight: 650;
    text-decoration: none;
  }

  main {
    min-height: 70vh;
  }

  .section {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
    padding: 64px 0;
  }

  .section.compact {
    padding-top: 28px;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(260px, 0.65fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
    padding-top: 56px;
  }

  .hero h1,
  .page-heading h1 {
    max-width: 12ch;
    margin: 0;
    font-size: clamp(3rem, 8vw, 6.6rem);
    line-height: 0.93;
    letter-spacing: 0;
  }

  .hero p,
  .page-heading p {
    max-width: 680px;
    color: var(--muted);
    font-size: clamp(1.08rem, 2vw, 1.35rem);
  }

  .hero-portrait {
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    background: var(--panel);
  }

  .hero-portrait img {
    aspect-ratio: 4 / 5;
    height: 100%;
    object-fit: cover;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.65rem 0.95rem;
    border: 1px solid var(--ink);
    border-radius: 8px;
    background: var(--ink);
    color: white;
    font-weight: 750;
    text-decoration: none;
  }

  .button.secondary {
    background: transparent;
    color: var(--ink);
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.4rem;
  }

  .section-heading h2,
  .page-heading h1 {
    margin-top: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .project-card,
  .list-card,
  .job-card {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    overflow: hidden;
  }

  .resume-list {
    display: grid;
    gap: 1rem;
  }

  .job-card ul {
    margin: 0.8rem 0 0;
    padding-left: 1.2rem;
  }

  .job-card li + li {
    margin-top: 0.35rem;
  }

  .project-image {
    display: block;
    background: var(--soft);
  }

  .project-image img {
    aspect-ratio: 16 / 10;
    width: 100%;
    object-fit: cover;
  }

  .project-copy,
  .list-card,
  .job-card {
    padding: 1.1rem;
  }

  .project-copy h3,
  .list-card h2,
  .job-card h2 {
    margin: 0.2rem 0 0.45rem;
    line-height: 1.18;
  }

  .project-copy p,
  .list-card p,
  .job-card p {
    color: var(--muted);
  }

  .eyebrow {
    margin: 0;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.9rem;
  }

  .tag-row span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.18rem 0.55rem;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 650;
  }

  .split {
    display: grid;
    grid-template-columns: 0.78fr 1.22fr;
    gap: 2rem;
    align-items: start;
  }

  .prose {
    max-width: 760px;
  }

  .prose h1 {
    margin-bottom: 0.5rem;
    font-size: clamp(2.4rem, 5vw, 4.8rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .prose p,
  .prose li {
    color: #343a40;
  }

  .datastar-note {
    margin-top: 2rem;
    border-top: 1px solid var(--line);
    padding-top: 1.25rem;
  }

  .prose img {
    border-radius: 8px;
  }

  .meta {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .site-footer {
    border-top: 1px solid var(--line);
    color: var(--muted);
  }

  @media (max-width: 820px) {
    .site-header,
    .site-footer,
    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero,
    .split {
      grid-template-columns: 1fr;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .hero {
      padding-top: 28px;
    }
  }
</style>
