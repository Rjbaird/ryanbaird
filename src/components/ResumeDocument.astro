---
import {
  activeEmployment,
  careerMetadata,
  educationEntries,
  formatPhone,
  formatResumeRange,
  topSkills,
} from "../lib/resume";

const { print = false } = Astro.props;
---

<article class:list={["resume-document", { "is-print": print }]}>
  <header class="resume-header">
    <div>
      <h1>Ryan Baird</h1>
      <p>{careerMetadata.title} {careerMetadata.headline}</p>
    </div>
    <address>
      <a href={`mailto:${careerMetadata.email}`}>{careerMetadata.email}</a>
      <a href={careerMetadata.website}>{careerMetadata.website.replace("https://", "")}</a>
      <a href={careerMetadata.github}>github.com/Rjbaird</a>
      <a href={careerMetadata.linkedin}>LinkedIn</a>
      <span>{careerMetadata.location}</span>
      <span>{formatPhone(careerMetadata.phone)}</span>
    </address>
  </header>

  <section class="resume-section">
    <h2>Skills</h2>
    <p>{topSkills.join(" · ")}</p>
  </section>

  <section class="resume-section">
    <h2>Experience</h2>
    {activeEmployment.map((job) => (
      <section class="resume-entry">
        <div class="resume-entry-heading">
          <div>
            <h3>{job.title}</h3>
            <p>{job.company} · {job.location} · {job.type}</p>
          </div>
          <p>{formatResumeRange(job)}</p>
        </div>
        <ul>
          {job.highlights.map((highlight) => <li>{highlight}</li>)}
        </ul>
        <p class="resume-skills">{job.skills.join(" · ")}</p>
      </section>
    ))}
  </section>

  <section class="resume-section">
    <h2>Education</h2>
    {educationEntries.map((entry) => (
      <section class="resume-entry">
        <div class="resume-entry-heading">
          <div>
            <h3>{entry.name}</h3>
            <p>{entry.degree}</p>
          </div>
          <p>{formatResumeRange(entry)}</p>
        </div>
        <ul>
          {entry.highlights.map((highlight) => <li>{highlight}</li>)}
        </ul>
      </section>
    ))}
  </section>
</article>

<style>
  .resume-document {
    display: grid;
    gap: 1.6rem;
    color: var(--ink, #191919);
  }

  .resume-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.5rem;
    align-items: start;
    border-bottom: 2px solid var(--ink, #191919);
    padding-bottom: 1rem;
  }

  .resume-header h1 {
    margin: 0;
    font-size: 3rem;
    line-height: 0.95;
    letter-spacing: 0;
  }

  .resume-header p,
  .resume-entry p,
  .resume-section p {
    margin: 0.2rem 0 0;
  }

  address {
    display: grid;
    gap: 0.15rem;
    color: var(--muted, #5b626b);
    font-style: normal;
    text-align: right;
  }

  .resume-section {
    display: grid;
    gap: 0.85rem;
  }

  .resume-section h2 {
    margin: 0;
    color: var(--accent-strong, #7c2d12);
    font-size: 0.85rem;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .resume-entry {
    display: grid;
    gap: 0.45rem;
    break-inside: avoid;
  }

  .resume-entry-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: start;
  }

  .resume-entry-heading h3 {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .resume-entry-heading > p,
  .resume-skills {
    color: var(--muted, #5b626b);
    font-size: 0.9rem;
  }

  ul {
    margin: 0;
    padding-left: 1.15rem;
  }

  li + li {
    margin-top: 0.2rem;
  }

  .resume-document.is-print {
    gap: 0.22in;
    font-size: 9.2pt;
    line-height: 1.34;
  }

  .is-print .resume-header {
    grid-template-columns: minmax(0, 1fr) 2.25in;
    gap: 0.25in;
    padding-bottom: 0.12in;
  }

  .is-print .resume-header h1 {
    font-size: 26pt;
  }

  .is-print .resume-section {
    gap: 0.08in;
  }

  .is-print .resume-entry {
    gap: 0.04in;
  }

  .is-print .resume-entry-heading h3 {
    font-size: 10pt;
  }

  .is-print .resume-entry-heading > p,
  .is-print .resume-skills {
    font-size: 8.4pt;
  }

  @media (max-width: 720px) {
    .resume-header,
    .resume-entry-heading {
      grid-template-columns: 1fr;
    }

    address {
      text-align: left;
    }
  }
</style>
